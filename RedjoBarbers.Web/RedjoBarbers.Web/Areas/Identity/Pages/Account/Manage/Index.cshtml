@page
@model IndexModel
@{
    ViewData["Title"] = "Профил";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<section class="inner-hero-section">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8 col-xl-7">
                <div class="inner-hero-content narrow mx-auto">
                    <span class="section-kicker">Настройки на акаунта</span>
                    <h1 class="inner-page-title">Управление на личния Ви профил</h1>
                    <p class="inner-page-text">
                        Поддържайте информацията в акаунта си актуална, за да осигурите бърз и безпроблемен процес при резервации и контакт.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="account-manage-section">
    <div class="container">
        <div class="manage-shell">
            <div class="manage-card">
                <div class="booking-form-head">
                    <span class="section-kicker">Данни за профила</span>
                    <h3>Актуализиране на информацията</h3>
                    <p>Редактирайте своите данни по-долу.</p>
                </div>

                <partial name="_StatusMessagesPartial" for="StatusMessage" />

                <form id="profile-form" method="post" class="lux-form">
                    <div asp-validation-summary="ModelOnly" class="form-error-summary text-danger" role="alert"></div>

                    <div class="lux-form-grid">
                        <div class="lux-form-group">
                            <label class="lux-label">Потребителско име</label>
                            <input class="lux-input" value="@Model.Username" disabled />
                        </div>
                    </div>

                    <div class="lux-form-grid two-cols">
                        <div class="lux-form-group">
                            <label asp-for="Input.FirstName" class="lux-label"></label>
                            <input asp-for="Input.FirstName" class="lux-input" />
                            <span asp-validation-for="Input.FirstName" class="field-validation text-danger"></span>
                        </div>

                        <div class="lux-form-group">
                            <label asp-for="Input.LastName" class="lux-label"></label>
                            <input asp-for="Input.LastName" class="lux-input" />
                            <span asp-validation-for="Input.LastName" class="field-validation text-danger"></span>
                        </div>
                    </div>

                    <div class="lux-form-grid two-cols">
                        <div class="lux-form-group">
                            <label asp-for="Input.DateOfBirth" class="lux-label"></label>
                            <input asp-for="Input.DateOfBirth" class="lux-input" data-picker="date-of-birth" />
                            <span asp-validation-for="Input.DateOfBirth" class="field-validation text-danger"></span>
                        </div>

                        <div class="lux-form-group">
                            <label asp-for="Input.PhoneNumber" class="lux-label"></label>
                            <input asp-for="Input.PhoneNumber" class="lux-input" />
                            <span asp-validation-for="Input.PhoneNumber" class="field-validation text-danger"></span>
                        </div>
                    </div>

                    <div class="lux-form-grid">
                        <div class="lux-form-group">
                            <label asp-for="Input.Email" class="lux-label"></label>
                            <input asp-for="Input.Email" class="lux-input" />
                            <span asp-validation-for="Input.Email" class="field-validation text-danger"></span>
                        </div>
                    </div>

                    <div class="lux-form-actions">
                        <button id="update-profile-button" type="submit" class="btn btn-gold">Запази промените</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}