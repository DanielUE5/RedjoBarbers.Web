@page
@model LogoutModel
@{
    ViewData["Title"] = "Изход";
}

<div class="container mt-5">
    <div class="text-center">

        <h2 class="mb-4">Изход от профила</h2>

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="alert alert-warning">
                Сигурни ли сте, че искате да излезете от профила си?
            </div>

            <form asp-area="Identity"
                  asp-page="/Account/Logout"
                  method="post"
                  class="d-inline">
                <button type="submit" class="btn btn-danger me-2">
                    Изход
                </button>
            </form>

            <a asp-area=""
               asp-controller="Home"
               asp-action="Index"
               class="btn btn-secondary">
                Към началната страница
            </a>
        }
        else
        {
            <div id="logoutMessage"
                 class="alert alert-success text-center"
                 data-redirect="@Url.Action("Index", "Home", new { area = "" })">

                <h5>Успешно излязохте от профила си.</h5>

                <p class="mt-2 mb-2">
                    Ще бъдете пренасочени към началната страница след
                    <strong id="countdown">2</strong> секунди...
                </p>

                <div class="mt-2">
                    <div class="spinner-border text-success" role="status"></div>
                </div>

                <a asp-area=""
                       asp-controller="Home"
                       asp-action="Index"
                       class="btn btn-primary mt-3">
                    Към началната страница
                </a>
            </div>
        }
    </div>
</div>