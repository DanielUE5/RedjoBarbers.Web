@model RedjoBarbers.Web.ViewModels.AdminPanelViewModel
@using RedjoBarbers.Web.Data.Models
@using RedjoBarbers.Web.Data.Models.Enums

@{
    ViewData["Title"] = "Админ панел";
}

<section class="inner-hero-section">
    <div class="container">
        <div class="inner-hero-content">
            <span class="section-kicker">Administrative Control</span>
            <h1 class="inner-page-title">Админ панел за управление на записвания и отзиви</h1>
            <p class="inner-page-text">
                Централизирано място за преглед на часове, актуализиране на статуси и управление на клиентски отзиви.
            </p>
        </div>
    </div>
</section>

<section class="admin-dashboard-section">
    <div class="container">
        <partial name="_StatusMessagesPartial" />
        <div class="admin-topbar">
            <div class="admin-title-wrap">
                <h2 class="text-gold">Admin Dashboard</h2>
                <span class="admin-badge">ADMIN</span>
            </div>
        </div>

        <div class="admin-section-block">
            <div class="section-heading d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
                <div>
                    <h2 class="section-title mb-2">Резервации</h2>
                    <p class="section-subtitle mb-0">
                        Преглед на всички записвания и промяна на техния статус.
                    </p>
                </div>
            </div>

            @if (!Model.Appointments.Any())
            {
                <div class="empty-box">
                    <p class="mb-0">Няма записани часове.</p>
                </div>
            }
            else
            {
                <div class="admin-table-shell">
                    <div class="table-responsive">
                        <table class="table admin-lux-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Услуга</th>
                                    <th>Клиент</th>
                                    <th>Номер</th>
                                    <th>Дата</th>
                                    <th>Статус</th>
                                    <th class="text-end">Промени</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (Appointment a in Model.Appointments)
                                {
                                    string statusClass = a.Status switch
                                    {
                                        AppointmentStatus.Pending => "status-badge pending",
                                        AppointmentStatus.Confirmed => "status-badge confirmed",
                                        AppointmentStatus.Cancelled => "status-badge cancelled",
                                        _ => "status-badge neutral"
                                    };

                                    <tr>
                                        <td class="fw-semibold">@a.BarberService?.Name</td>
                                        <td>@a.CustomerName</td>
                                        <td>@a.CustomerPhone</td>
                                        <td>@Html.DisplayFor(_ => a.AppointmentDate)</td>
                                        <td>
                                            <span class="@statusClass">@a.Status</span>
                                        </td>
                                        <td class="text-end">
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <form asp-area="Admin"
                                                      asp-controller="Admin"
                                                      asp-action="UpdateStatus"
                                                      method="post"
                                                      class="admin-inline-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@a.Id" />

                                                    <select name="status" class="lux-input admin-inline-select">
                                                        @foreach (AppointmentStatus s in Enum.GetValues(typeof(AppointmentStatus)))
                                                        {
                                                            <option value="@s" selected="@(a.Status == s ? "selected" : null)">
                                                                @s
                                                            </option>
                                                        }
                                                    </select>

                                                    <button type="submit" class="btn btn-outline-lux btn-sm">
                                                        Запази
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <div class="admin-section-block">
            <div class="section-heading d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
                <div>
                    <h2 class="section-title mb-2">Отзиви</h2>
                    <p class="section-subtitle mb-0">
                        Управление на публикуваните мнения от клиенти.
                    </p>
                </div>
            </div>

            @if (!Model.Reviews.Any())
            {
                <div class="empty-box">
                    <p class="mb-0">Няма налични отзиви.</p>
                </div>
            }
            else
            {
                <div class="admin-table-shell">
                    <div class="table-responsive">
                        <table class="table admin-lux-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Потребител</th>
                                    <th>Оценка</th>
                                    <th>Коментар</th>
                                    <th>Дата</th>
                                    <th class="text-end">Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (Review r in Model.Reviews)
                                {
                                    <tr>
                                        <td>@r.CustomerName</td>
                                        <td>
                                            <span class="status-badge rating">
                                                @r.Rating / 5
                                            </span>
                                        </td>
                                        <td class="admin-comment-cell">
                                            @r.Comments
                                        </td>
                                        <td>@Html.DisplayFor(_ => r.ReviewDate)</td>
                                        <td class="text-end">
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <form asp-area="Admin"
                                                      asp-controller="Admin"
                                                      asp-action="DeleteReview"
                                                      method="post"
                                                      class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@r.Id" />

                                                    <button type="submit"
                                                            class="btn btn-gold btn-sm"
                                                            onclick="return confirm('Да изтрия ли този отзив?');">
                                                        Delete
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
