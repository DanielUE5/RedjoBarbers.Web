@using System.Security.Claims

@{
    bool isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    bool isAdmin = User.IsInRole("Admin");

    string? fullName =
        User.FindFirst("fullName")?.Value ??
        User.FindFirst(ClaimTypes.Name)?.Value ??
        User.Identity?.Name;

    if (string.IsNullOrWhiteSpace(fullName))
    {
        fullName = "Акаунт";
    }
}

<div class="user-menu-wrap">
    @if (!isAuthenticated)
    {
        <div class="user-menu-guest">
            <a asp-area="Identity"
                   asp-page="/Account/Login"
                   class="btn btn-outline-lux btn-sm">
                Вход
            </a>

            <a asp-area="Identity"
                   asp-page="/Account/Register"
                   class="btn btn-gold btn-sm">
                Регистрация
            </a>
        </div>
    }
    else
    {
        <div class="dropdown">
            <button class="user-menu-trigger"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false">
                <span class="user-avatar-circle">
                    @(fullName![0].ToString().ToUpper())
                </span>
                <span class="user-menu-name">@fullName</span>
                <i class="bi bi-chevron-down"></i>
            </button>

            <ul class="dropdown-menu dropdown-menu-end user-menu-dropdown">
                <li class="user-menu-header">
                    <span class="user-menu-overline">Влезли сте като</span>
                    <strong><span class="text-gold">@fullName</span></strong>
                </li>

                <li><hr class="dropdown-divider" /></li>

                <li>
                    <a class="dropdown-item"
                           asp-controller="Appointment"
                           asp-action="MyAppointments">
                        <i class="bi bi-calendar-check"></i>
                        <span>Моите резервации</span>
                    </a>
                </li>

                <li>
                    <a class="dropdown-item"
                           asp-area="Identity"
                           asp-page="/Account/Manage/Index">
                        <i class="bi bi-person-gear"></i>
                        <span>Настройки на профила</span>
                    </a>
                </li>

                <li>
                    <a class="dropdown-item"
                           asp-controller="Review"
                           asp-action="Index">
                        <i class="bi bi-star"></i>
                        <span>Отзиви</span>
                    </a>
                </li>

                @if (isAdmin)
                {
                    <li><hr class="dropdown-divider" /></li>

                    <li>
                        <a class="dropdown-item"
                               asp-area="Admin"
                               asp-controller="Admin"
                               asp-action="Index">
                            <i class="bi bi-shield-lock"></i>
                            <span>Админ панел</span>
                        </a>
                    </li>
                }

                <li><hr class="dropdown-divider" /></li>

                <li>
                    <a class="dropdown-item dropdown-item-danger"
                           asp-area="Identity"
                           asp-page="/Account/Logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Изход</span>
                    </a>
                </li>
            </ul>
        </div>
    }
</div>