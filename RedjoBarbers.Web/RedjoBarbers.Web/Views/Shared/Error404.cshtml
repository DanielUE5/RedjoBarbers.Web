@{
    ViewData["Title"] = "Страницата не е намерена";
}

<section class="error-page-section d-flex align-items-center">
    <div class="container">
        <div class="error-page-card text-center mx-auto">

            <div class="error-code">404</div>

            <h1 class="error-title">Страницата не беше намерена</h1>

            <p class="error-text">
                Изглежда, че страницата, която търсите, не съществува или адресът е въведен неправилно.
            </p>

            <div class="error-divider"></div>

            <div class="error-actions d-flex flex-column flex-md-row justify-content-center gap-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-gold">
                    Към началната страница
                </a>

                <a asp-controller="Appointment" asp-action="Index" class="btn btn-outline-lux">
                    Виж записаните часове
                </a>
            </div>

        </div>
    </div>
</section>