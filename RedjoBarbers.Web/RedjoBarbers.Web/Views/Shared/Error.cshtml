@{
    ViewData["Title"] = "Грешка";
}

<section class="error-page-section">
    <div class="container">
        <div class="error-page-card">
            <h1>Грешка</h1>
            <h2>Възникна проблем при зареждането на страницата</h2>
            <p>
                Моля, опитайте отново или се върнете към началната страница.
            </p>

            <div class="error-actions">
                <a asp-controller="Home" asp-action="Index" class="filter-btn primary-btn">
                    Към началната страница
                </a>
            </div>
        </div>
    </div>
</section>