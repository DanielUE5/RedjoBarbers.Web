@{
    ViewData["Title"] = "Възникна грешка";
}

<section class="error-page-section d-flex align-items-center">
    <div class="container">
        <div class="error-page-card text-center mx-auto">

            <div class="error-code">500</div>

            <h1 class="error-title">Възникна неочаквана грешка</h1>

            <p class="error-text">
                Нещо се обърка при обработката на заявката.
                Моля, опитайте отново след малко или се свържете с нас.
            </p>

            <div class="error-divider"></div>

            <div class="error-actions d-flex flex-column flex-md-row justify-content-center gap-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-gold">
                    Към началната страница
                </a>

                <a asp-controller="Home" asp-action="Contacts" class="btn btn-outline-lux">
                    Свържете се с нас
                </a>
            </div>
        </div>
    </div>
</section>