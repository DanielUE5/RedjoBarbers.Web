@model RedjoBarbers.Web.ViewModels.Appointments.AppointmentDetailsViewModel

@{
    ViewData["Title"] = "Изтриване на резервация";
}

<section class="inner-hero-section">
    <div class="container">
        <div class="inner-hero-content narrow">
            <span class="section-kicker">Изтриване на резервация</span>
            <h1 class="inner-page-title">Преглед на резервацията преди изтриване</h1>
            <p class="inner-page-text">
                Потвърдете детайлите по-долу преди да премахнете резервацията от системата.
            </p>
        </div>
    </div>
</section>

<section class="appointment-delete-section">
    <div class="container">
        <partial name="_StatusMessagesPartial" />

        <div class="delete-appointment-shell">
            <div class="delete-appointment-card">
                <div class="delete-appointment-head">
                    <span class="section-kicker">Внимание</span>
                    <h2>Сигурни ли сте, че искате да изтриете тази резервация?</h2>
                    <p>
                        Това действие ще премахне резервацията и трябва да се използва само ако тя вече не е необходима.
                    </p>
                </div>

                <div class="delete-appointment-summary">
                    <div class="appointment-meta-item">
                        <span>Клиент</span>
                        <strong>@Model.CustomerName</strong>
                    </div>

                    <div class="appointment-meta-item">
                        <span>Бръснар</span>
                        <strong>@Model.BarberName</strong>
                    </div>

                    <div class="appointment-meta-item">
                        <span>Услуга</span>
                        <strong>@Model.BarberServiceName</strong>
                    </div>

                    <div class="appointment-meta-item">
                        <span>Дата и час</span>
                        <strong>@Model.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</strong>
                    </div>

                    <div class="appointment-meta-item">
                        <span>Имейл</span>
                        <strong>@Model.CustomerEmail</strong>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.CustomerPhone))
                    {
                        <div class="appointment-meta-item">
                            <span>Телефон</span>
                            <strong>@Model.CustomerPhone</strong>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <div class="appointment-note-box mt-4">
                        <span>Бележки</span>
                        <p>@Model.Notes</p>
                    </div>
                }

                <form asp-action="Delete" method="post" class="lux-form-actions mt-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <button type="submit" class="btn btn-gold">Изтрий резервацията</button>
                    <a asp-action="Index" class="btn btn-outline-lux">Връщане назад</a>
                </form>
            </div>
        </div>
    </div>
</section>