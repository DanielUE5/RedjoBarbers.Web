@model RedjoBarbers.Web.ViewModels.MyAppointmentsPageViewModel
@using RedjoBarbers.Web.Data.Models
@using RedjoBarbers.Web.Data.Models.Enums

@{
    ViewData["Title"] = "Моите срещи";
}

<section class="inner-hero-section">
    <div class="container">
        <div class="inner-hero-content">
            <span class="section-kicker">Client Dashboard</span>
            <h1 class="inner-page-title">Вашите записани часове и последни отзиви</h1>
            <p class="inner-page-text">
                Преглед на предстоящи и минали посещения, плюс последните публикувани от вас отзиви.
            </p>
        </div>
    </div>
</section>

<section class="my-appointments-section">
    <div class="container">
        <partial name="_StatusMessagesPartial" />

        <div class="section-heading d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
            <div>
                <span class="section-kicker">Appointments</span>
                <h2 class="section-title mb-2">Вашите резервации</h2>
                <p class="section-subtitle mb-0">
                    Управлявайте резервациите си от едно място.
                </p>
            </div>

            <a asp-controller="Appointment" asp-action="Create" class="btn btn-gold">
                Запазете нов час
            </a>
        </div>

        @if (!Model.Appointments.Any())
        {
            <div class="empty-box">
                <p class="mb-0">Все още нямате записани часове.</p>
            </div>
        }
        else
        {
            <div class="appointments-grid">
                @foreach (Appointment appointment in Model.Appointments)
                {
                    string statusClass = appointment.Status switch
                    {
                        AppointmentStatus.Pending => "status-badge pending",
                        AppointmentStatus.Confirmed => "status-badge confirmed",
                        AppointmentStatus.Cancelled => "status-badge cancelled",
                        _ => "status-badge neutral"
                    };

                    <article class="appointment-card">
                        <div class="appointment-card-top">
                            <div>
                                <span class="@statusClass">@appointment.Status</span>
                                <h3>@appointment.BarberService?.Name</h3>
                            </div>

                            <div class="appointment-date-block">
                                <strong>@appointment.AppointmentDate.ToString("dd")</strong>
                                <span>@appointment.AppointmentDate.ToString("MMM")</span>
                            </div>
                        </div>

                        <div class="appointment-meta-list">
                            <div class="appointment-meta-item">
                                <span>Barber</span>
                                <strong>@(appointment.Barber?.Name ?? "N/A")</strong>
                            </div>

                            <div class="appointment-meta-item">
                                <span>Date & Time</span>
                                <strong>@appointment.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</strong>
                            </div>

                            <div class="appointment-meta-item">
                                <span>Name</span>
                                <strong>@appointment.CustomerName</strong>
                            </div>

                            <div class="appointment-meta-item">
                                <span>Email</span>
                                <strong>@appointment.CustomerEmail</strong>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(appointment.CustomerPhone))
                            {
                                <div class="appointment-meta-item">
                                    <span>Phone</span>
                                    <strong>@appointment.CustomerPhone</strong>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(appointment.Notes))
                        {
                            <div class="appointment-note-box">
                                <span>Notes</span>
                                <p>@appointment.Notes</p>
                            </div>
                        }

                        <div class="appointment-actions">
                            <a asp-controller="Appointment"
                                   asp-action="Update"
                                   asp-route-id="@appointment.Id"
                                   class="btn btn-outline-lux btn-sm">
                                Променете часа
                            </a>

                            <a asp-controller="Appointment"
                                   asp-action="Delete"
                                   asp-route-id="@appointment.Id"
                                   class="btn btn-gold btn-sm">
                                Отменете часа
                            </a>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>

<section class="my-reviews-section">
    <div class="container">
        <div class="section-heading d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
            <div>
                <span class="section-kicker">Reviews</span>
                <h2 class="section-title mb-2">Вашите последни отзиви</h2>
                <p class="section-subtitle mb-0">
                    Бърз преглед на последната активност по review системата.
                </p>
            </div>

            <a asp-controller="Review" asp-action="Create" class="btn btn-outline-lux">
                Напишете отзив
            </a>
        </div>

        @if (!Model.Reviews.Any())
        {
            <div class="empty-box">
                <p class="mb-0">Все още нямате публикувани отзиви.</p>
            </div>
        }
        else
        {
            <div class="reviews-page-grid">
                @foreach (Review review in Model.Reviews.Take(6))
                {
                    <article class="review-showcase-card">
                        <div class="review-showcase-top">
                            <div>
                                <span class="review-service-tag">@review.BarberService?.Name</span>
                                <h3>@review.CustomerName</h3>
                            </div>

                            <small>@review.ReviewDate.ToString("dd.MM.yyyy")</small>
                        </div>

                        <div class="review-stars large">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= review.Rating)
                                {
                                    <i class="bi bi-star-fill"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star"></i>
                                }
                            }

                            <span class="review-score-text">@review.Rating/5</span>
                        </div>

                        <p class="review-showcase-text">@review.Comments</p>
                    </article>
                }
            </div>
        }
    </div>
</section>