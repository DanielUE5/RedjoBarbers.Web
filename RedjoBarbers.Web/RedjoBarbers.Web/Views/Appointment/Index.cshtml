@using RedjoBarbers.Web.ViewModels.Appointments
@model IEnumerable<RedjoBarbers.Web.ViewModels.Appointments.AppointmentListItemViewModel>

@{
    ViewData["Title"] = "Резервации";
}

<section class="inner-hero-section">
    <div class="container">
        <div class="inner-hero-content">
            <span class="section-kicker">Резервации</span>
            <h1 class="inner-page-title">Управление на запазени часове</h1>
            <p class="inner-page-text">
                Премиум преглед на всички резервации с бърз достъп до редакция и изтриване.
            </p>
        </div>
    </div>
</section>

<section class="appointments-page-section">
    <div class="container">
        <partial name="_StatusMessagesPartial" />

        <div class="section-heading d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
            <div>
                <span class="section-kicker">Преглед</span>
                <h2 class="section-title mb-2">Всички запазени посещения</h2>
                <p class="section-subtitle mb-0">
                    Удобен начин да следите и управлявате своите посещения.
                </p>
            </div>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a asp-controller="Appointment" asp-action="Create" class="btn btn-gold">
                    Нова резервация
                </a>
            }
            else
            {
                <a asp-area="Identity"
                       asp-page="/Account/Login"
                       asp-route-returnUrl="/Appointment/Create"
                       class="btn btn-gold">
                    Нова резервация
                </a>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="empty-box">
                <p class="mb-0">В момента няма налични резервации.</p>
            </div>
        }
        else
        {
            <div class="appointments-grid">
                @foreach (AppointmentListItemViewModel appointment in Model)
                {
                    <article class="appointment-card">
                        <div class="appointment-card-top">
                            <div>
                                <span class="appointment-badge">Планирана</span>
                                <h3>@appointment.CustomerName</h3>
                            </div>

                            <div class="appointment-date-block">
                                <strong>@appointment.AppointmentDate.ToString("dd")</strong>
                                <span>@appointment.AppointmentDate.ToString("MMM")</span>
                            </div>
                        </div>

                        <div class="appointment-meta-list">
                            <div class="appointment-meta-item">
                                <span>Бръснар</span>
                                <strong>@appointment.BarberName</strong>
                            </div>

                            <div class="appointment-meta-item">
                                <span>Услуга</span>
                                <strong>@appointment.BarberServiceName</strong>
                            </div>

                            <div class="appointment-meta-item">
                                <span>Дата и час</span>
                                <strong>@appointment.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</strong>
                            </div>

                            <div class="appointment-meta-item">
                                <span>Статус</span>
                                <strong>@appointment.Status</strong>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(appointment.Notes))
                        {
                            <div class="appointment-note-box">
                                <span>Бележки</span>
                                <p>@appointment.Notes</p>
                            </div>
                        }      
                    </article>
                }
            </div>
        }
    </div>
</section>