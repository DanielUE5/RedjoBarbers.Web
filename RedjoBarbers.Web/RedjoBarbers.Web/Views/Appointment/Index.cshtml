@using RedjoBarbers.Web.Data.Models
@using RedjoBarbers.Web.Data.Models.Enums
@model RedjoBarbers.Web.ViewModels.AppointmentFilterViewModel

@{
    ViewData["Title"] = "График";
}
<form method="get" class="appointments-filter-card">
    <div class="filter-header">
        <h2>Филтриране на часове</h2>
        <p>Избери период и допълнителни критерии, за да видиш по-точно записаните часове.</p>
    </div>

    <div class="filter-grid">
        <div class="filter-group">
            <label for="FromDate">От дата</label>
            <input id="FromDate"
                   type="date"
                   name="FromDate"
                   value="@Model.FromDate?.ToString("dd.MM.yyyy")"
                   class="filter-input" />

        </div>

        <div class="filter-group">
            <label for="ToDate">До дата</label>
            <input id="ToDate"
                   type="date"
                   name="ToDate"
                   value="@Model.ToDate?.ToString("dd.MM.yyyy")"
                   class="filter-input" />
        </div>

        <div class="filter-group">
            <label for="Status">Статус</label>
            <select id="Status" name="Status" class="filter-input">
                <option value="">Всички статуси</option>
                @foreach (var status in Enum.GetValues(typeof(RedjoBarbers.Web.Data.Models.Enums.AppointmentStatus)))
                {
                    <option value="@status" selected="@(Model.Status?.ToString() == status.ToString())">
                        @status
                    </option>
                }
            </select>
        </div>

        <div class="filter-group">
            <label for="BarberId">Бръснар</label>
            <select id="BarberId" name="BarberId" class="filter-input">
                <option value="">Всички бръснари</option>
                @foreach (var b in Model.Barbers)
                {
                    <option value="@b.Value" selected="@(Model.BarberId?.ToString() == b.Value)">
                        @b.Text
                    </option>
                }
            </select>
        </div>
    </div>

    <div class="filter-actions">
        <button type="submit" class="filter-btn primary-btn">Филтрирай</button>
        <a asp-action="Index" class="filter-btn secondary-btn">Изчисти</a>
    </div>
</form>
<h2>Записани часове</h2>

@{
    string returnUrl = Url.Action("Create", "Appointment")!;
}
<p>
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <a asp-action="Create"
           class="btn btn-primary cta-btn">
            Планирай посещение
        </a>
    }
    else
    {
        <a asp-area="Identity"
           asp-page="/Account/Login"
           asp-route-returnUrl="@returnUrl"
           class="btn btn-primary cta-btn">
            Планирай посещение
        </a>
    }
</p>

@if (Model == null || !Model.Appointments.Any())
{
    <tr> 
        <td colspan="3" class="text-lg text-muted mt-2"> 
            <i class="bi bi-calendar-x me-2"></i> Все още няма записани часове. Натиснете "Планирай посещение".
        </td> 
    </tr>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Статус</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (Appointment a in Model.Appointments)
            {
                <tr>
                    <td>@a.AppointmentDate</td>
                    <td>@a.Status</td>
                </tr>
            }
        </tbody>
    </table>
}