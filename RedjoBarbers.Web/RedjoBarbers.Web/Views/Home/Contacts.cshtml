@using RedjoBarbers.Web.Data.Models
@using RedjoBarbers.Web.Infrastructure.Helpers
@model IEnumerable<Barber>

@{
    ViewData["Title"] = "Контакти";
}

<section class="contacts-hero">
    <div class="container">
        <h1>Контакти</h1>
        <p>
            Обадете ни се директно или ни пишете в социалните мрежи. По-долу ще намерите бърз контакт с всеки наш бръснар.
        </p>
    </div>
</section>

<section class="contacts-info">
    <div class="container">
        <h2>Запознай се с нашите бръснари тук:</h2>
        @if (!Model.Any())
        {
            <p>В момента няма налични контакти на бръснари. Моля, свържете се с нас на общия имейл или телефон за повече информация.</p>
        }
        else
        {
            <div class="contacts-list">
                @foreach (Barber b in Model)
                {
                    string? safePhotoUrl = UrlSecurityHelper.SafeHttpUrlOrNull(b.PhotoUrl);
                    string? safeInstagramUrl = UrlSecurityHelper.SafeHttpUrlOrNull(b.InstagramUrl);
                    string? safeFacebookUrl = UrlSecurityHelper.SafeHttpUrlOrNull(b.FacebookUrl);
                    string? safePhoneHref = UrlSecurityHelper.SafeTelHrefOrNull(b.PhoneNumber);

                    <div class="contact-item">
                        @if (!string.IsNullOrWhiteSpace(safePhotoUrl))
                        {
                            <img class="contact-photo" src="@safePhotoUrl" alt="@b.Name" loading="lazy" />
                        }

                        <div class="contact-details">
                            <div class="contact-header">
                                <span class="contact-name">@b.Name</span>

                                @if (!string.IsNullOrWhiteSpace(safePhoneHref))
                                {
                                    <a class="contact-phone"
                                           href="@safePhoneHref"
                                           aria-label="Обадете се на @b.Name на телефон @b.PhoneNumber">
                                        @b.PhoneNumber
                                    </a>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(b.Bio))
                            {
                                <p class="contact-bio">@b.Bio</p>
                            }

                            <div class="contact-links">
                                @if (!string.IsNullOrWhiteSpace(safeInstagramUrl))
                                {
                                    <a href="@safeInstagramUrl"
                                           target="_blank"
                                           rel="noopener noreferrer"
                                           class="social-link"
                                           aria-label="Instagram профил на @b.Name">
                                        <i class="bi bi-instagram"></i>
                                    </a>
                                }

                                @if (!string.IsNullOrWhiteSpace(safeFacebookUrl))
                                {
                                    <a href="@safeFacebookUrl"
                                           target="_blank"
                                           rel="noopener noreferrer"
                                           class="social-link"
                                           aria-label="Facebook профил на @b.Name">
                                        <i class="bi bi-facebook"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <partial name="_GoogleLocation" />
    </div>
</section>