@model RedjoBarbers.Web.ViewModels.ReviewIndexPageViewModel

@{
    ViewData["Title"] = "Отзиви";
}

<section class="py-4">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
            <h2 class="mb-0">Отзиви</h2>

            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a asp-area=""
                       asp-controller="Review"
                       asp-action="Create"
                       class="btn btn-primary cta-btn">
                    Напишете отзив
                </a>
            }
            else
            {
                <a asp-area="Identity"
                       asp-page="/Account/Login"
                       asp-route-returnUrl="@Url.Action("Create", "Review")"
                       class="btn btn-primary cta-btn">
                    Напишете отзив
                </a>
            }
        </div>

        <form method="get" class="appointments-filter-card mb-4">
            <div class="filter-header">
                <h2>Филтриране на отзиви</h2>
                <p>Можете да разгледате всички отзиви или да ги филтрирате по услуга и начин на подреждане.</p>
            </div>

            <div class="filter-grid">
                <div class="filter-group">
                    <label for="BarberServiceId">Услуга</label>
                    <select id="BarberServiceId" name="barberServiceId" class="filter-input">
                        <option value="">Всички услуги</option>
                        @foreach (SelectListItem service in Model.Services)
                        {
                            <option value="@service.Value" selected="@(Model.BarberServiceId?.ToString() == service.Value)">
                                @service.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="filter-group">
                    <label for="SortReviews">Подреди по</label>
                    <select id="SortReviews" name="sortReviews" class="filter-input">
                        <option value="" selected="@(string.IsNullOrWhiteSpace(Model.SortReviews))">Най-нови</option>
                        <option value="rating" selected="@(Model.SortReviews == "rating")">Най-висок рейтинг</option>
                    </select>
                </div>
            </div>

            <div class="filter-actions">
                <button type="submit" class="filter-btn primary-btn">Приложи</button>
                <a asp-action="Index" class="filter-btn secondary-btn">Изчисти</a>
            </div>
        </form>

        @if (!Model.Reviews.Any())
        {
            <p class="text-muted">Все още няма публикувани отзиви.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Услуга</th>
                            <th>Клиент</th>
                            <th>Рейтинг</th>
                            <th>Дата</th>
                            <th>Коментар</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (ReviewIndexItemViewModel r in Model.Reviews)
                        {
                            <tr>
                                <td class="fw-semibold">@r.ServiceName</td>

                                <td>@r.CustomerName</td>

                                <td>
                                    <span class="text-warning me-2">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= r.Rating)
                                            {
                                                <i class="bi bi-star-fill"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-star"></i>
                                            }
                                        }
                                    </span>
                                    <span class="text-muted small">(@r.Rating/5)</span>
                                </td>

                                <td>@r.ReviewDate.ToString("dd.MM.yyyy")</td>

                                <td style="min-width: 260px">
                                    @r.Comments
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>