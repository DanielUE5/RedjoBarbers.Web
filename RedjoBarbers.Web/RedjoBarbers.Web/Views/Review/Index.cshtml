@model RedjoBarbers.Web.ViewModels.ReviewIndexPageViewModel

@{
    ViewData["Title"] = "Отзиви";
}

<section class="inner-hero-section">
    <div class="container">
        <div class="inner-hero-content">
            <span class="section-kicker">Клиентски мнения</span>
            <h1 class="inner-page-title">Отзиви, които изграждат доверие</h1>
            <p class="inner-page-text">
                Вижте какво казват нашите клиентите след всяко посещение.
            </p>
        </div>
    </div>
</section>

<section class="reviews-page-section">
    <div class="container">
        <div class="section-heading d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
            <div>
                <span class="section-kicker">Отзиви</span>
                <h2 class="section-title mb-2">Какво казват клиентите</h2>
                <p class="section-subtitle mb-0">
                    Доволни клиенти, които се връщат отново.
                </p>
            </div>

            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a asp-area=""
                       asp-controller="Review"
                       asp-action="Create"
                       class="btn btn-gold">
                    Напишете отзив
                </a>
            }
            else
            {
                <a asp-area="Identity"
                       asp-page="/Account/Login"
                       asp-route-returnUrl="@Url.Action("Create", "Review")"
                       class="btn btn-gold">
                    Напишете отзив
                </a>
            }
        </div>

        <form method="get" class="reviews-filter-panel">
            <input type="hidden" name="currentPage" value="1" />

            <div class="reviews-filter-head">
                <h3>Филтриране на отзиви</h3>
                <p>Разгледай всички отзиви или ги филтрирай по услуга и начин на сортиране.</p>
            </div>

            <div class="reviews-filter-grid">
                <div class="lux-form-group">
                    <label for="BarberServiceId" class="lux-label">Услуга</label>
                    <select id="BarberServiceId" name="barberServiceId" class="lux-input">
                        <option value="">Всички услуги</option>
                        @foreach (SelectListItem service in Model.Services)
                        {
                            <option value="@service.Value" selected="@(Model.BarberServiceId?.ToString() == service.Value)">
                                @service.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="lux-form-group">
                    <label for="SortReviews" class="lux-label">Сортиране</label>
                    <select id="SortReviews" name="sortReviews" class="lux-input">
                        <option value="newest" selected="@(Model.SortReviews == "newest")">Най-нови</option>
                        <option value="rating" selected="@(string.IsNullOrWhiteSpace(Model.SortReviews) || Model.SortReviews == "rating")">Най-висока оценка</option>
                    </select>
                </div>
            </div>

            <div class="lux-form-actions">
                <button type="submit" class="btn btn-gold">Приложи</button>
                <a asp-action="Index" class="btn btn-outline-lux">Изчисти</a>
            </div>
        </form>

        @if (!Model.Reviews.Any())
        {
            <div class="empty-box">
                <p class="mb-0">Все още няма публикувани отзиви.</p>
            </div>
        }
        else
        {
            <div class="reviews-page-grid">
                @foreach (ReviewIndexItemViewModel r in Model.Reviews)
                {
                    <article class="review-showcase-card">
                        <div class="review-showcase-top">
                            <div>
                                <span class="review-service-tag">@r.ServiceName</span>
                                <h3>@r.CustomerName</h3>
                            </div>

                            <small>@r.ReviewDate.ToString("dd.MM.yyyy")</small>
                        </div>

                        <div class="review-stars large">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= r.Rating)
                                {
                                    <i class="bi bi-star-fill"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star"></i>
                                }
                            }
                            <span class="review-score-text">@r.Rating/5</span>
                        </div>

                        <p class="review-showcase-text">@r.Comments</p>
                    </article>
                }
            </div>
        }

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Странициране на отзиви" class="mt-5">
                <ul class="pagination pagination-lux justify-content-center">

                    <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-barberServiceId="@Model.BarberServiceId"
                               asp-route-sortReviews="@Model.SortReviews"
                               asp-route-currentPage="@(Model.Page - 1)">
                            Предишна
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link"
                                   asp-action="Index"
                                   asp-route-barberServiceId="@Model.BarberServiceId"
                                   asp-route-sortReviews="@Model.SortReviews"
                                   asp-route-currentPage="@i">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                               asp-action="Index"
                               asp-route-barberServiceId="@Model.BarberServiceId"
                               asp-route-sortReviews="@Model.SortReviews"
                               asp-route-currentPage="@(Model.Page + 1)">
                            Следваща
                        </a>
                    </li>

                </ul>
            </nav>
        }
    </div>
</section>